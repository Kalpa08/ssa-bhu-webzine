---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map(issue => ({
    params: { id: issue.id },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content } = await render(issue);

// Fetch all published content
const echoes = await getCollection('echoes');
const interfaceCol = await getCollection('interface');
const canvas = await getCollection('canvas');
const journeys = await getCollection('journeys');

const allArticles = [...echoes, ...interfaceCol, ...canvas, ...journeys];

// Filter to ONLY include articles tagged with THIS issue's ID
const issueArticles = allArticles.filter(article => article.data.issue?.trim() === issue.id);

// Group articles by their pillar for the Table of Contents
const groupedArticles = {
  "Canvas (Fine Arts)": issueArticles.filter(a => a.collection === 'canvas').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  "Echoes (Literature)": issueArticles.filter(a => a.collection === 'echoes').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  "Interface (Science & Technology)": issueArticles.filter(a => a.collection === 'interface').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  "Journeys (Travel & Culture)": issueArticles.filter(a => a.collection === 'journeys').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
};
---

<BaseLayout title={`Issue ${issue.data.issueNumber} - ${issue.data.theme} | Nahor`}>
  <div class="max-w-7xl mx-auto px-4 py-12 md:py-20 bg-[#faf9f6]">
    
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-start">
      
      {/* Left Column: The Designed Cover Image (Sticky) */}
      <div class="w-full lg:w-1/2 sticky top-12">
        {issue.data.image && (
          <img 
            src={issue.data.image} 
            alt={`Cover for Issue ${issue.data.issueNumber}`} 
            class="w-full h-auto object-cover shadow-2xl rounded-sm border border-gray-200"
          />
        )}
      </div>

      {/* Right Column: Information & Articles */}
      <div class="w-full lg:w-1/2 flex flex-col">
        
        {/* Header / Editor's Note */}
        <header class="mb-16 border-b border-gray-300 pb-12">
          <h1 class="text-4xl md:text-5xl font-serif font-bold mb-4 text-gray-900">
            Issue {issue.data.issueNumber} — {issue.data.theme}
          </h1>
          <p class="text-lg text-gray-500 uppercase tracking-widest mb-10">Published {issue.data.year}</p>
          
          <div class="prose prose-lg md:prose-xl font-serif text-gray-800 leading-relaxed">
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-gray-400 mb-6">Editor's Note</h3>
            <Content />
          </div>
        </header>

        {/* Table of Contents */}
        <section>
          <h3 class="text-2xl font-serif font-bold mb-10 uppercase tracking-widest text-gray-900">Inside This Issue</h3>
          
          {issueArticles.length === 0 ? (
            <p class="text-gray-600 italic bg-gray-100 p-6 rounded border border-gray-200">
              Content for this issue is currently being curated. Ensure the "Issue Tag" in your articles is typed exactly as <strong class="text-red-700">{issue.id}</strong>.
            </p>
          ) : (
            <div class="space-y-12">
              {Object.entries(groupedArticles).map(([pillar, articles]) => (
                articles.length > 0 && (
                  <div>
                    <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-green-800 mb-6 border-b border-gray-200 pb-2">
                      {pillar}
                    </h4>
                    <ul class="space-y-6">
                      {articles.map(article => (
                        <li>
                          <a href={`/${article.collection}/${article.id}`} class="block group">
                            <h5 class="text-2xl font-serif font-medium group-hover:text-green-700 transition-colors">
                              {article.data.title}
                            </h5>
                            <p class="text-gray-500 mt-1 font-sans text-sm tracking-wide uppercase">
                              by {article.data.author}
                            </p>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              ))}
            </div>
          )}
        </section>

      </div>
    </div>
  </div>
</BaseLayout>
