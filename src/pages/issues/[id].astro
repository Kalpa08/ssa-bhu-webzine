---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map(issue => ({
    params: { id: issue.id },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content } = await render(issue);

const echoes = await getCollection('echoes');
const interfaceCol = await getCollection('interface');
const canvas = await getCollection('canvas');
const journeys = await getCollection('journeys');

const allArticles = [...echoes, ...interfaceCol, ...canvas, ...journeys];
const issueArticles = allArticles.filter(article => article.data.issue?.trim() === issue.id);

const groupedArticles = {
  "Canvas": issueArticles.filter(a => a.collection === 'canvas').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  "Echoes": issueArticles.filter(a => a.collection === 'echoes').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  "Interface": issueArticles.filter(a => a.collection === 'interface').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  "Journeys": issueArticles.filter(a => a.collection === 'journeys').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
};
---

<BaseLayout title={`Issue ${issue.data.issueNumber} | Nahor`}>
  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      
      {/* Left Column: Cover Image */}
      <div class="w-full">
        {issue.data.image && (
          <img 
            src={issue.data.image} 
            alt="Issue Cover" 
            class="w-full h-auto object-contain shadow-xl"
          />
        )}
      </div>

      {/* Right Column: Editorial & Contents */}
      <div class="w-full">
        <header class="mb-12">
          <h1 class="text-4xl font-bold font-serif mb-2">Issue {issue.data.issueNumber} — {issue.data.theme}</h1>
          <p class="text-gray-500 uppercase tracking-widest">{issue.data.year}</p>
        </header>

        <section class="prose prose-lg mb-16">
          <h2 class="text-xl font-bold uppercase tracking-wider text-gray-700 mb-4">Editor's Note</h2>
          <div class="text-gray-800 leading-relaxed font-serif">
            <Content />
          </div>
        </section>

        <section>
          <h2 class="text-xl font-bold uppercase tracking-wider text-gray-700 mb-8">Table of Contents</h2>
          {Object.entries(groupedArticles).map(([pillar, articles]) => (
            articles.length > 0 && (
              <div class="mb-8">
                <h4 class="font-bold text-green-800 mb-3">{pillar}</h4>
                <ul class="space-y-3">
                  {articles.map(article => (
                    <li>
                      <a href={`/${article.collection}/${article.id}`} class="hover:underline text-lg">
                        {article.data.title} <span class="text-gray-500 text-sm italic">— {article.data.author}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          ))}
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
