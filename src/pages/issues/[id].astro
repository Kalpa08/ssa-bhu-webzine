---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map(issue => ({
    params: { id: issue.id },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content } = await render(issue);

// Fetch all published content
const echoes = await getCollection('echoes');
const interfaceCol = await getCollection('interface');
const canvas = await getCollection('canvas');
const journeys = await getCollection('journeys');

const allArticles = [...echoes, ...interfaceCol, ...canvas, ...journeys];

// Safeguard: use .trim() to ignore accidental spaces typed in the CMS
const issueArticles = allArticles.filter(article => article.data.issue?.trim() === issue.id);

// Group articles by their pillar to build the sidebar menu
const groupedArticles = {
  canvas: issueArticles.filter(a => a.collection === 'canvas').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  echoes: issueArticles.filter(a => a.collection === 'echoes').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  interface: issueArticles.filter(a => a.collection === 'interface').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  journeys: issueArticles.filter(a => a.collection === 'journeys').sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
};
---

<BaseLayout title={`Issue ${issue.data.issueNumber} - ${issue.data.theme} | Nahor`}>
  <div class="relative min-h-screen w-full bg-gray-900 text-white font-serif overflow-hidden">
    
    {/* Full Screen Background Image with dark overlay for text readability */}
    {issue.data.image && (
      <div class="absolute inset-0 z-0">
        <img 
          src={issue.data.image} 
          alt={`Cover for ${issue.data.theme}`} 
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-black/20"></div>
      </div>
    )}

    {/* Magazine Overlay Content */}
    <div class="relative z-10 w-full h-full min-h-screen flex flex-col p-8 md:p-12 max-w-7xl mx-auto">
      
      {/* Top Header */}
      <header class="flex flex-col md:flex-row justify-between items-center md:items-start border-b border-white/30 pb-8 mb-12">
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-7xl md:text-9xl font-bold tracking-tight">NAHOR</h1>
          <p class="text-xl italic mt-4 text-gray-200">— A Journal of Art, Literature, Science & Journeys —</p>
        </div>
        <div class="text-center md:text-right mt-6 md:mt-0">
          <p class="text-2xl font-bold uppercase tracking-widest text-[#d4af37]">Issue {issue.data.issueNumber}</p>
          <p class="text-lg uppercase tracking-widest mt-1">{issue.data.year}</p>
        </div>
      </header>

      {/* Main Content Area */}
      <div class="flex flex-col md:flex-row flex-1 gap-12">
        
        {/* Left Sidebar: Curated Article List */}
        <aside class="w-full md:w-1/3 space-y-10">
          {Object.entries(groupedArticles).map(([pillar, articles]) => (
            articles.length > 0 && (
              <div class="border-t border-white/20 pt-4">
                <h3 class="text-lg font-bold uppercase tracking-[0.2em] text-[#d4af37] mb-4">{pillar}</h3>
                <ul class="space-y-5">
                  {articles.map(article => (
                    <li>
                      <a href={`/${article.collection}/${article.id}`} class="block group">
                        <h4 class="text-2xl font-medium group-hover:text-[#d4af37] transition-colors leading-snug">
                          {article.data.title}
                        </h4>
                        <p class="text-sm text-gray-300 mt-2 font-sans tracking-wide">
                          by {article.data.author}
                        </p>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          ))}

          {issueArticles.length === 0 && (
            <p class="text-sm italic text-red-300 bg-red-900/50 p-4 rounded border border-red-500/50">
              Articles missing. Ensure the "Issue Tag" in your articles is typed exactly as <strong>{issue.id}</strong>.
            </p>
          )}
        </aside>

        {/* Center: Theme Title */}
        <main class="w-full md:w-2/3 flex flex-col items-center justify-center text-center pb-24">
          <p class="uppercase tracking-[0.4em] text-lg text-gray-300 mb-4">Theme</p>
          <h2 class="text-6xl md:text-[8rem] font-bold leading-none shadow-black drop-shadow-2xl">
            {issue.data.theme}
          </h2>
        </main>
      </div>

      {/* Editor's Note (Bottom Left) */}
      <footer class="mt-auto max-w-xl border-l-2 border-[#d4af37] pl-6 pb-8">
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37] mb-3">Editor's Note</h3>
        <div class="prose prose-invert prose-p:leading-relaxed text-gray-200">
          <Content />
        </div>
      </footer>
      
    </div>
  </div>
</BaseLayout>
