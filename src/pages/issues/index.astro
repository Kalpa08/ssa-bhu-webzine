---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('issues');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---
<BaseLayout title="Issues | Nahor">
  <div style="max-width: 900px; margin: 60px auto; padding: 0 20px;">
    <h1 style="font-size: 36px; border-bottom: 2px solid #1A1A1A; padding-bottom: 10px; margin-bottom: 40px; text-align: center;">Curated Editions</h1>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 40px;">
      {sortedPosts.map(post => (
        <a href={`/issues/${post.id}`} style="text-decoration: none; color: inherit; transition: 0.3s; display: block;">
          <div style="padding: 15px; background: #fff; box-shadow: 0 8px 20px rgba(0,0,0,0.06); border: 1px solid #eaeaea; display: flex; flex-direction: column; align-items: center;">
            <img src={post.data.image} alt={post.data.title} style="width: 100%; max-height: 350px; object-fit: cover; margin-bottom: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);" />
            <h2 style="font-size: 22px; margin: 0 0 8px 0; font-family: 'Playfair Display', serif; text-align: center;">{post.data.title}</h2>
            <p style="margin: 0; font-family: 'Inter', sans-serif; font-size: 12px; color: #666; text-transform: uppercase; text-align: center; letter-spacing: 1px;">
              {new Date(post.data.publishDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
