---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('dialogues');
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} | Nahor`}>
  <div style="max-width: 650px; margin: 60px auto; padding: 0 20px;">
    <h1 style="font-size: 42px; margin: 20px 0 10px 0; line-height: 1.2;">{post.data.title}</h1>
    <div style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; border-bottom: 1px solid #ddd; padding-bottom: 20px; margin-bottom: 30px;">
      By {post.data.author} | {new Date(post.data.publishDate).toLocaleDateString()}
    </div>
    <div style="font-size: 18px; line-height: 1.8; color: #333;">
      <Content />
    </div>
  </div>
</BaseLayout>
