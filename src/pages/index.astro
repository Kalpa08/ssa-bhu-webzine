---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Nahor | Students' Society of Assam</title>
  </head>
  <body class="bg-magazine-paper text-magazine-ink font-sans min-h-screen">
    
    <!-- Navigation Bar -->
    <header class="border-b border-gray-300 py-6 px-6">
      <div class="max-w-4xl mx-auto flex justify-between items-center">
        <div class="font-serif text-2xl font-bold tracking-tight">Nahor.</div>
        <nav class="hidden md:flex space-x-8 text-sm font-bold text-gray-600">
          <a href="#" class="hover:text-magazine-ink transition-colors">Editorials</a>
          <a href="#" class="hover:text-magazine-ink transition-colors">Campus Life</a>
          <a href="#" class="hover:text-magazine-ink transition-colors">Gallery</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-3xl mx-auto py-24 px-6 text-center">
      
      <p class="text-sm font-bold tracking-widest text-gray-500 uppercase mb-4">Students' Society of Assam, BHU</p>
      
      <h1 class="text-5xl md:text-6xl font-serif font-bold mb-6 leading-tight">
        A record of culture, <br />
        <span class="text-gray-500 italic">and scholarly pursuit.</span>
      </h1>
      
      <p class="text-lg md:text-xl text-gray-600 mb-12 leading-relaxed font-serif">
        The premier digital publication exploring literature, academic excellence, and the vibrant heritage of Assam.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#" class="px-8 py-3 bg-magazine-ink text-magazine-paper text-sm font-bold rounded hover:opacity-80 transition-opacity w-full sm:w-auto">
          Read the Latest
        </a>
        <a href="/admin" class="px-8 py-3 border border-magazine-ink text-magazine-ink text-sm font-bold rounded hover:bg-gray-200 transition-colors w-full sm:w-auto">
          Editorial Login
        </a>
      </div>

    </main>
  </body>
</html>

