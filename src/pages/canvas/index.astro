---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('canvas');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---
<BaseLayout title="Canvas | Nahor">
  <div style="max-width: 900px; margin: 60px auto; padding: 0 20px;">
    <h1 style="font-size: 36px; border-bottom: 2px solid #1A1A1A; padding-bottom: 10px; margin-bottom: 40px; text-align: center;">Canvas (Fine Arts)</h1>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 30px;">
      {sortedPosts.map(post => (
        <a href={`/canvas/${post.id}`} style="text-decoration: none; color: inherit; transition: 0.3s; display: block;">
          <div style="border: 1px solid #ddd; padding: 10px; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <img src={post.data.image} alt={post.data.title} style="width: 100%; height: 200px; object-fit: cover; margin-bottom: 15px;" />
            <h2 style="font-size: 20px; margin: 0 0 5px 0; font-family: 'Playfair Display', serif;">{post.data.title}</h2>
            <p style="margin: 0; font-family: 'Inter', sans-serif; font-size: 12px; color: #666; text-transform: uppercase;">{post.data.author} | {post.data.medium}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
