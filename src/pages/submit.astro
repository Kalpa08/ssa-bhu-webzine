---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Submit | Nahor">
  <div style="max-width: 600px; margin: 80px auto; padding: 0 20px;">
    
    <h1 style="font-family: 'Playfair Display', serif; font-size: 42px; margin-bottom: 20px; color: #1A1A1A; text-align: center; letter-spacing: -1px;">
      Submit to Nahor
    </h1>
    <p style="text-align: center; color: #666; font-size: 15px; margin-bottom: 50px; line-height: 1.6; font-family: 'Inter', sans-serif;">
      We welcome original submissions across our four editorial pillars. Select the category that best fits your work and complete the form below.
    </p>

    <!-- Tally Form Embed -->
    <iframe data-tally-src="https://tally.so/embed/Gxg5Ee?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1" loading="lazy" width="100%" height="200" frameborder="0" marginheight="0" marginwidth="0" title="Submit to Nahor"></iframe>
    <script>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}</script>
    
  </div>
</BaseLayout>
