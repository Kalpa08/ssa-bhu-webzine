---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Submit | Nahor">
  <div style="max-width: 600px; margin: 80px auto; padding: 0 20px; text-align: center;">
    <h1 style="font-size: 42px; margin-bottom: 20px;">Contribute to Nahor</h1>
    <p style="font-size: 18px; line-height: 1.8; color: #444; margin-bottom: 40px;">
      We are currently accepting submissions for Art, Literature, Science & Technology, and Travel Journeys. 
      All submissions are reviewed through our editorial workflow.
    </p>
    
    <div style="padding: 40px; border: 1px solid #ddd; background: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
      <h2 style="font-size: 24px; margin-bottom: 15px; font-family: 'Playfair Display', serif;">Submission Portal Offline</h2>
      <p style="font-size: 15px; color: #666; font-family: 'Inter', sans-serif;">Our secure public submission form is currently being built. Please check back shortly to submit your drafts.</p>
    </div>
  </div>
</BaseLayout>
