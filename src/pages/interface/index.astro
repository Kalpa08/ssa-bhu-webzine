---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('interface');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---
<BaseLayout title="Interface | Nahor">
  <div style="max-width: 650px; margin: 60px auto; padding: 0 20px;">
    <h1 style="font-size: 36px; border-bottom: 2px solid #1A1A1A; padding-bottom: 10px; margin-bottom: 40px;">Interface (Science & Tech)</h1>
    {sortedPosts.map(post => (
      <div style="margin-bottom: 40px; padding-bottom: 30px; border-bottom: 1px solid #ddd;">
        <h2 style="font-size: 28px; margin: 0 0 10px 0;"><a href={`/interface/${post.id}`} style="text-decoration: none; color: #1A1A1A;">{post.data.title}</a></h2>
        <div style="font-family: 'Inter', sans-serif; font-size: 14px; color: #666; margin-bottom: 15px;">By {post.data.author} | {new Date(post.data.publishDate).toLocaleDateString()}</div>
      </div>
    ))}
  </div>
</BaseLayout>
