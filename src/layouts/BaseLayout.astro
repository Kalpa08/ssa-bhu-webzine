---
import '../styles/global.css';
const { title = "Nahor | Art. Literature. Science. Journeys." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Google Fonts: Playfair Display (Serif) & Inter (Sans-Serif) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <style>
      body { background-color: #F9F9F7; color: #1A1A1A; font-family: 'Playfair Display', serif; margin: 0; padding: 0;}
      
      /* Modern Magazine Header Styles */
      .site-header { border-bottom: 1px solid #ddd; padding: 0 20px; font-family: 'Inter', sans-serif; font-size: 12px; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600; background-color: #fff;}
      .header-container { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; height: 80px; }
      
      .nav-left a, .nav-center a, .nav-right a { color: #1A1A1A; text-decoration: none; transition: 0.2s; }
      .nav-left a:hover, .nav-center a:hover { color: #0A3B2C; }
      
      .nav-center { display: flex; gap: 30px; }
      
      /* Submit Button */
      .nav-right a { border: 1px solid #1A1A1A; padding: 10px 20px; border-radius: 3px; }
      .nav-right a:hover { background-color: #1A1A1A; color: #F9F9F7; }

      /* Mobile Menu Elements */
      .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 10px; }
      .hamburger span { display: block; width: 25px; height: 2px; background-color: #1A1A1A; margin: 5px 0; transition: 0.3s; }
      
      .mobile-menu { display: none; background-color: #F9F9F7; border-bottom: 1px solid #ddd; text-align: center; padding: 10px 0; font-family: 'Inter', sans-serif; font-size: 12px; text-transform: uppercase; font-weight: 600; letter-spacing: 1px;}
      .mobile-menu a { display: block; padding: 15px; color: #1A1A1A; text-decoration: none; border-bottom: 1px solid #eee; }
      .mobile-menu a:last-child { border-bottom: none; }
      .mobile-menu a:hover { color: #0A3B2C; background-color: #f0f0f0; }
      
      /* Responsive Breakpoints */
      @media (max-width: 850px) {
        .nav-center, .nav-right { display: none; }
        .hamburger { display: block; }
        .mobile-menu.active { display: block; }
      }
    </style>
  </head>
  <body>
    
    <!-- Editorial Masthead & Navigation -->
    <header style="padding: 40px 20px 20px 20px; border-bottom: 1px solid #eaeaea; background-color: #fff;">
      
      <!-- Huge Centered Logo -->
      <div style="text-align: center; margin-bottom: 30px;">
        <a href="/" style="font-family: 'Playfair Display', serif; font-size: 52px; font-weight: 700; color: #1A1A1A; text-decoration: none; letter-spacing: 4px; text-transform: uppercase;">
          Nahor
        </a>
      </div>
      
      <!-- Centered Navigation Bar -->
      <div style="display: flex; justify-content: center; align-items: center; gap: 30px; flex-wrap: wrap;">
        <a href="/about" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase;">ABOUT</a>
        <a href="/issues" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase;">ISSUES</a>
        <a href="/canvas" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase;">CANVAS</a>
        <a href="/echoes" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase;">ECHOES</a>
        <a href="/interface" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase;">INTERFACE</a>
        <a href="/journeys" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase;">JOURNEYS</a>
        <a href="/submit" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase; border: 1px solid #1A1A1A; padding: 8px 16px; margin-left: 10px;">SUBMIT</a>
      </div>
      
    </header>


    <!-- Mobile Dropdown Panel -->
    <div class="mobile-menu" id="mobile-nav">
      <a href="/about" style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #1A1A1A; text-decoration: none; letter-spacing: 1.5px;">ABOUT</a>
      <a href="/">Home</a>
      <a href="/issues">Issues</a>
      <a href="/canvas">Canvas</a>
      <a href="/echoes">Echoes</a>
      <a href="/interface">Interface</a>
      <a href="/journeys">Journeys</a>
      <a href="/submit" style="color: #0A3B2C;">Submit</a>
    </div>

    <!-- Page Content Injected Here -->
    <slot />

    <!-- Mobile Menu Toggle Script -->
    <script>
      const btn = document.getElementById('hamburger-btn');
      const menu = document.getElementById('mobile-nav');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('active');
        });
      }
    </script>
    <!-- Global Footer -->
    <footer style="border-top: 1px solid #eaeaea; padding: 60px 20px; margin-top: 80px; text-align: center; font-family: 'Inter', sans-serif;">
      
      <!-- Footer Links -->
      <div style="margin-bottom: 20px;">
        <a href="/about" style="color: #666; text-decoration: none; font-size: 11px; margin: 0 15px; letter-spacing: 1.5px; text-transform: uppercase; transition: color 0.2s ease;">About</a>
        <a href="mailto:nahormag@gmail.com" style="color: #666; text-decoration: none; font-size: 11px; margin: 0 15px; letter-spacing: 1.5px; text-transform: uppercase; transition: color 0.2s ease;">Contact</a>
        <a href="/issues" style="color: #666; text-decoration: none; font-size: 11px; margin: 0 15px; letter-spacing: 1.5px; text-transform: uppercase; transition: color 0.2s ease;">Archives</a>
      </div>

      <!-- Copyright Notice -->
      <div style="color: #999; font-size: 12px; letter-spacing: 0.5px;">
        &copy; {new Date().getFullYear()} Nahor. All rights reserved. <br/>
        <span style="font-size: 11px; margin-top: 8px; display: inline-block;">Published independently. Founded at Banaras Hindu University by the Students' Society of Assam.</span>
      </div>
      
    </footer>
  </body>
</html>
